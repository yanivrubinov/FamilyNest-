<!DOCTYPE html>
<html lang="he">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1"/>
<title>FamilyNest</title>
<script src="https://cdn.tailwindcss.com"></script>
<style>
*{box-sizing:border-box;-webkit-tap-highlight-color:transparent;margin:0;padding:0}
body{font-family:'Segoe UI',Arial,sans-serif;background:#0f0f1a;color:#f0ece4;overflow-x:hidden;min-height:100vh}
.card{background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.08);border-radius:16px;overflow:hidden}
.card-warm{background:rgba(249,115,22,.07);border:1px solid rgba(249,115,22,.18);border-radius:16px}
.btn-grad{background:linear-gradient(135deg,#f97316,#ec4899);color:#fff;border:none;border-radius:12px;font-weight:700;cursor:pointer;font-family:inherit;font-size:15px;padding:12px;width:100%;transition:opacity .2s}
.btn-grad:hover{opacity:.85}
.btn-ghost{background:transparent;color:#f97316;border:1.5px solid #f97316;border-radius:12px;font-weight:700;cursor:pointer;font-family:inherit;font-size:14px;padding:11px;width:100%;transition:background .2s}
.btn-ghost:hover{background:rgba(249,115,22,.1)}
.btn-sm{padding:5px 13px;border-radius:8px;font-size:12px;font-weight:700;cursor:pointer;font-family:inherit;border:none}
input,textarea,select{background:rgba(255,255,255,.07);border:1.5px solid rgba(255,255,255,.12);border-radius:10px;padding:10px 13px;width:100%;color:#f0ece4;font-size:15px;font-family:inherit;outline:none;transition:border .2s;direction:rtl}
input:focus,textarea:focus,select:focus{border-color:#f97316}
input::placeholder,textarea::placeholder{color:rgba(240,236,228,.3)}
label{font-size:13px;font-weight:700;color:rgba(249,115,22,.9);display:block;margin-bottom:4px}
.field{margin-bottom:.85rem}
.bottom-nav{height:64px;background:rgba(10,8,22,.96);backdrop-filter:blur(12px);border-top:1px solid rgba(255,255,255,.07);display:flex;flex-shrink:0}
.bnav-btn{flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:3px;border:none;background:transparent;cursor:pointer;font-size:10px;font-weight:700;color:rgba(255,255,255,.38);font-family:inherit;transition:color .15s}
.bnav-btn.active,.bnav-btn:hover{color:#f97316}
.bnav-icon{font-size:21px;transition:transform .15s}
.bnav-btn.active .bnav-icon{transform:scale(1.12)}
.add-ring{width:44px;height:44px;border-radius:50%;background:linear-gradient(135deg,#f97316,#ec4899);display:flex;align-items:center;justify-content:center;font-size:22px;color:#fff;box-shadow:0 4px 14px rgba(249,115,22,.4)}
.tag{display:inline-block;padding:2px 9px;border-radius:999px;font-size:11px;font-weight:700;background:rgba(249,115,22,.15);color:#f97316}
.upload-zone{border:2px dashed rgba(249,115,22,.4);border-radius:12px;padding:1.25rem;text-align:center;cursor:pointer;transition:background .2s}
.upload-zone:hover{background:rgba(249,115,22,.06)}
.modal-bg{position:fixed;inset:0;background:rgba(0,0,0,.6);z-index:100;display:flex;align-items:flex-end;justify-content:center}
.modal-bg.hidden{display:none}
.modal-sheet{background:#16122a;border-radius:22px 22px 0 0;width:100%;max-width:600px;max-height:88vh;overflow-y:auto;padding:1.5rem 1.25rem 2.5rem;direction:rtl;animation:slideUp .25s ease}
@keyframes slideUp{from{transform:translateY(50px);opacity:0}to{transform:none;opacity:1}}
@keyframes fadeIn{from{opacity:0;transform:translateY(-8px)}to{opacity:1;transform:none}}
.fade-in{animation:fadeIn .3s ease}
::-webkit-scrollbar{width:4px}::-webkit-scrollbar-thumb{background:#f9731633;border-radius:2px}
#toast{position:fixed;top:18px;left:50%;transform:translateX(-50%);color:#fff;padding:10px 22px;border-radius:12px;font-size:14px;font-weight:700;z-index:9999;direction:rtl;display:none;box-shadow:0 6px 22px rgba(0,0,0,.4);white-space:nowrap;max-width:90vw}
.member-row{display:flex;align-items:center;gap:10px;background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.08);border-radius:12px;padding:10px 12px;margin-bottom:8px}
.avatar-circle{width:40px;height:40px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:1rem;font-weight:700;flex-shrink:0}
.dot-bg{background-image:radial-gradient(rgba(249,115,22,.13) 1px,transparent 1px);background-size:22px 22px}
</style>
</head>
<body>
<div id="toast"></div>

<!-- ═══════════════════════════════
     מסך כניסה / הרשמה
═══════════════════════════════ -->
<div id="screen-auth" style="position:fixed;inset:0;display:flex;align-items:center;justify-content:center;background:linear-gradient(160deg,#0f0c2e,#0f0f1a 55%,#1a0e2e);padding:1rem;z-index:200;overflow-y:auto" class="dot-bg">
  <div style="width:100%;max-width:420px">

    <!-- לוגו -->
    <div style="text-align:center;margin-bottom:1.75rem">
      <div style="width:76px;height:76px;margin:0 auto .9rem;border-radius:22px;background:linear-gradient(135deg,#f97316,#ec4899);display:flex;align-items:center;justify-content:center;font-size:2.2rem;box-shadow:0 8px 28px rgba(249,115,22,.4)">🏡</div>
      <h1 style="font-size:2rem;font-weight:900;background:linear-gradient(135deg,#f97316,#ec4899);-webkit-background-clip:text;-webkit-text-fill-color:transparent;letter-spacing:-1px">FamilyNest</h1>
      <p style="color:rgba(240,236,228,.4);font-size:13px;margin-top:4px">הרשת החברתית הפרטית של המשפחה שלך</p>
    </div>

    <!-- פאנל כניסה -->
    <div id="auth-login" style="background:rgba(255,255,255,.06);backdrop-filter:blur(14px);border:1px solid rgba(255,255,255,.1);border-radius:22px;padding:2rem 1.5rem">
      <h2 style="font-size:1.1rem;font-weight:800;color:#f0ece4;text-align:center;margin-bottom:1.25rem;direction:rtl">כניסה לחשבון</h2>
      <div class="field"><label>📧 אימייל</label><input id="li-email" type="email" placeholder="name@email.com" style="direction:ltr"/></div>
      <div class="field"><label>🔒 סיסמה</label><input id="li-pass" type="password" placeholder="••••••••" style="direction:ltr"/></div>
      <button class="btn-grad" onclick="doLogin()" style="margin-bottom:.75rem">כניסה →</button>
      <div style="text-align:center;margin-top:.5rem">
        <span style="color:rgba(240,236,228,.45);font-size:14px">אין לך חשבון? </span>
        <span onclick="showAuthTab('signup')" style="color:#f97316;font-weight:700;font-size:14px;cursor:pointer;text-decoration:underline">הרשמה כאן ›</span>
      </div>
    </div>

    <!-- פאנל הרשמה -->
    <div id="auth-signup" style="display:none;background:rgba(255,255,255,.06);backdrop-filter:blur(14px);border:1px solid rgba(255,255,255,.1);border-radius:22px;padding:2rem 1.5rem">
      <h2 style="font-size:1.1rem;font-weight:800;color:#f0ece4;text-align:center;margin-bottom:1.25rem;direction:rtl">הרשמה למשפחה</h2>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px">
        <div class="field"><label>שם פרטי</label><input id="su-fn" type="text" placeholder="ישראל"/></div>
        <div class="field"><label>שם משפחה</label><input id="su-ln" type="text" placeholder="ישראלי"/></div>
      </div>
      <div class="field"><label>📧 אימייל</label><input id="su-email" type="email" placeholder="name@email.com" style="direction:ltr"/></div>
      <div class="field"><label>🔒 סיסמה (מינ׳ 6 תווים)</label><input id="su-pass" type="password" placeholder="••••••••" style="direction:ltr"/></div>

      <!-- Join / Create -->
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:1rem">
        <button id="tab-join-btn" onclick="setFamilyTab('join')"
          style="padding:9px;border-radius:10px;font-size:13px;font-weight:700;cursor:pointer;font-family:inherit;border:1.5px solid #f97316;background:linear-gradient(135deg,#f97316,#ec4899);color:#fff">
          🔗 הצטרף למשפחה קיימת
        </button>
        <button id="tab-create-btn" onclick="setFamilyTab('create')"
          style="padding:9px;border-radius:10px;font-size:13px;font-weight:700;cursor:pointer;font-family:inherit;border:1.5px solid rgba(249,115,22,.4);background:transparent;color:rgba(249,115,22,.8)">
          ✨ צור משפחה חדשה
        </button>
      </div>

      <div id="su-panel-join" class="field">
        <label>🏷️ קוד משפחה קיים</label>
        <input id="su-join-code" type="text" placeholder="לדוגמה: COHEN2024" style="direction:ltr;text-transform:uppercase"/>
        <p style="font-size:11px;color:rgba(240,236,228,.3);margin-top:4px;direction:rtl">בקש/י את הקוד מהמנהל/ת של קבוצת המשפחה שלך</p>
      </div>
      <div id="su-panel-create" style="display:none" class="field">
        <label>🆕 בחר/י קוד משפחה חדש</label>
        <input id="su-new-code" type="text" placeholder="לדוגמה: LEVI2025" style="direction:ltr;text-transform:uppercase"/>
        <p style="font-size:11px;color:rgba(240,236,228,.3);margin-top:4px;direction:rtl">הקוד ישמש להזמנת בני משפחה — תירשם/י כמנהל/ת</p>
      </div>

      <button id="btn-signup" class="btn-grad" onclick="doSignUp()" style="margin-bottom:.75rem">הצטרף/י למשפחה קיימת 🔗</button>
      <div style="text-align:center;margin-top:.5rem">
        <span style="color:rgba(240,236,228,.45);font-size:14px">יש לך כבר חשבון? </span>
        <span onclick="showAuthTab('login')" style="color:#f97316;font-weight:700;font-size:14px;cursor:pointer;text-decoration:underline">‹ חזרה לכניסה</span>
      </div>
    </div>

  </div>
</div>

<!-- ═══════════════════════════════
     האפליקציה הראשית
═══════════════════════════════ -->
<div id="screen-app" style="position:fixed;inset:0;display:none;flex-direction:column">

  <!-- כותרת -->
  <div style="background:rgba(10,8,22,.95);backdrop-filter:blur(12px);border-bottom:1px solid rgba(255,255,255,.07);padding:.7rem 1rem;display:flex;align-items:center;justify-content:space-between;flex-shrink:0;z-index:30;direction:rtl">
    <div style="display:flex;align-items:center;gap:8px">
      <span style="font-size:1.2rem">🏡</span>
      <span style="font-weight:900;font-size:1rem;background:linear-gradient(135deg,#f97316,#ec4899);-webkit-background-clip:text;-webkit-text-fill-color:transparent">FamilyNest</span>
    </div>
    <div style="display:flex;gap:8px;align-items:center">
      <button onclick="openFamilyModal()" style="background:rgba(249,115,22,.12);border:1px solid rgba(249,115,22,.3);color:#f97316;border-radius:10px;padding:5px 13px;font-size:13px;font-weight:700;cursor:pointer;font-family:inherit">👨‍👩‍👧‍👦 המשפחה שלי</button>
      <button onclick="doLogout()" style="background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.1);border-radius:8px;padding:5px 12px;color:rgba(240,236,228,.45);font-size:12px;cursor:pointer;font-family:inherit">יציאה</button>
    </div>
  </div>

  <!-- תוכן -->
  <div style="flex:1;overflow-y:auto;-webkit-overflow-scrolling:touch">

    <!-- פיד -->
    <div id="tab-feed" style="max-width:640px;margin:0 auto;padding:1rem;direction:rtl">
      <h2 style="font-size:1.05rem;font-weight:800;color:#f0ece4;margin-bottom:1rem">📖 פיד משפחתי</h2>
      <div id="feed-container"></div>
    </div>

    <!-- הוסף זיכרון -->
    <div id="tab-add" style="display:none;max-width:640px;margin:0 auto;padding:1rem;direction:rtl">
      <h2 style="font-size:1.05rem;font-weight:800;color:#f0ece4;margin-bottom:1rem">✨ הוסף זיכרון חדש</h2>
      <div class="card" style="padding:1.25rem">
        <div class="field">
          <label>✍️ פרסם בשם</label>
          <select id="post-author-select" style="background:rgba(255,255,255,.07);border:1.5px solid rgba(255,255,255,.12);border-radius:10px;padding:10px 13px;width:100%;color:#f0ece4;font-size:15px;font-family:inherit;outline:none;direction:rtl"></select>
        </div>
        <div class="field">
          <label>📝 מה קרה?</label>
          <textarea id="post-text" placeholder="שתפ/י את המשפחה בסיפור…" rows="4" style="resize:vertical"></textarea>
        </div>
        <div class="field">
          <label>📷 תמונה (אופציונלי, מקס 3MB)</label>
          <div class="upload-zone" onclick="document.getElementById('post-img-inp').click()">
            <div style="font-size:1.8rem;margin-bottom:.3rem">📸</div>
            <p style="font-size:14px;font-weight:700;color:#f97316;margin:0">לחצ/י לבחירת תמונה</p>
            <p style="font-size:11px;color:rgba(240,236,228,.3);margin:3px 0 0">JPG · PNG · WEBP בלבד</p>
          </div>
          <input id="post-img-inp" type="file" accept="image/jpeg,image/png,image/webp" style="display:none" onchange="previewImage(this)"/>
          <img id="post-img-preview" style="display:none;width:100%;border-radius:10px;margin-top:.65rem;max-height:280px;object-fit:cover"/>
        </div>
        <button class="btn-grad" onclick="submitPost()">פרסם 🏡</button>
      </div>
    </div>

    <!-- פרופיל -->
    <div id="tab-profile" style="display:none;max-width:640px;margin:0 auto;padding:1rem;direction:rtl">
      <h2 style="font-size:1.05rem;font-weight:800;color:#f0ece4;margin-bottom:1rem">👤 הפרופיל שלי</h2>
      <div class="card-warm" style="padding:1.25rem;margin-bottom:1rem">
        <div style="display:flex;align-items:center;gap:14px">
          <div id="my-avatar" style="width:64px;height:64px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:1.6rem;flex-shrink:0"></div>
          <div>
            <h3 id="my-name-display" style="font-size:1.1rem;font-weight:800;color:#f0ece4;margin-bottom:3px"></h3>
            <p id="my-family-code" style="font-size:12px;color:rgba(240,236,228,.4);margin-bottom:4px"></p>
            <span id="my-role-badge" class="tag"></span>
          </div>
        </div>
      </div>
      <h4 style="font-size:.9rem;font-weight:700;color:#f0ece4;margin-bottom:.75rem">📌 הפוסטים שלי</h4>
      <div id="my-posts"></div>
    </div>

  </div>

  <!-- ניווט תחתון -->
  <nav class="bottom-nav">
    <button class="bnav-btn active" id="bnav-home" onclick="showTab('feed')">
      <span class="bnav-icon">🏠</span><span>בית</span>
    </button>
    <button class="bnav-btn" id="bnav-add" onclick="showTab('add')">
      <div class="add-ring">＋</div><span>זיכרון</span>
    </button>
    <button class="bnav-btn" id="bnav-profile" onclick="showTab('profile')">
      <span class="bnav-icon">👤</span><span>פרופיל</span>
    </button>
  </nav>
</div>

<!-- מודל משפחה -->
<div id="family-modal" class="modal-bg hidden" onclick="if(event.target===this)closeFamilyModal()">
  <div class="modal-sheet">
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:1.25rem">
      <h2 style="font-size:1.1rem;font-weight:800;color:#f0ece4">👨‍👩‍👧‍👦 המשפחה שלי</h2>
      <button onclick="closeFamilyModal()" style="background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.12);border-radius:8px;padding:5px 11px;cursor:pointer;font-size:17px;color:#f97316">✕</button>
    </div>
    <p style="font-size:12px;color:rgba(240,236,228,.35);margin-bottom:.85rem">חברים מצטרפים אוטומטית כשנרשמים עם קוד המשפחה שלך</p>
    <div id="members-list"></div>
  </div>
</div>

<!-- מודל עריכה -->
<div id="edit-modal" class="modal-bg hidden" onclick="if(event.target===this)closeEditModal()">
  <div class="modal-sheet" style="max-height:60vh">
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:1.25rem">
      <h2 style="font-size:1.1rem;font-weight:800;color:#f0ece4">✏️ עריכת חבר משפחה</h2>
      <button onclick="closeEditModal()" style="background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.12);border-radius:8px;padding:5px 11px;cursor:pointer;font-size:17px;color:#f97316">✕</button>
    </div>
    <div class="field"><label>שם</label><input id="edit-name" type="text"/></div>
    <div class="field"><label>תפקיד</label><input id="edit-role" type="text"/></div>
    <div class="field"><label>אימוג׳י</label><input id="edit-emoji" type="text" style="direction:ltr"/></div>
    <button onclick="saveEdit()" class="btn-grad" style="padding:10px;font-size:14px">שמור שינויים ✅</button>
  </div>
</div>

<script>
// ─── נתוני דמה ────────────────────────────────────────────────────
const COLORS = ['#f97316','#ec4899','#6366f1','#10b981','#0ea5e9','#f59e0b','#8b5cf6','#14b8a6'];

let currentUser = null; // { id, name, role, familyCode, emoji, color }

let members = [
  { id:'m1', name:'אני (מנהל)', role:'מנהל', emoji:'👑', color:'#f97316', isMe:true },
  { id:'m2', name:'סבתא מרים', role:'סבתא',  emoji:'👵', color:'#ec4899' },
  { id:'m3', name:'דוד קרלוס', role:'דוד',   emoji:'👨', color:'#6366f1' },
  { id:'m4', name:'שרה',       role:'אחות',  emoji:'👩', color:'#10b981' },
];

let posts = [
  { id:'p1', authorId:'m2', authorName:'סבתא מרים', text:'סוף סוף כל הורדים פורחים יחד! 🌹 סבא היה אוהב לשבת לידם כל ערב.', imageUrl:'', emoji:'🌹🌷🌸', likes:['m3','m4'], comments:[{author:'דוד קרלוס',text:'מהמם! 😍'},{author:'שרה',text:'כמה יפה ❤️'}], date:'20 במאי 2025' },
  { id:'p2', authorId:'m3', authorName:'דוד קרלוס', text:'סופיה עשתה את צעדיה הראשונים! ישר לזרועות הסבתא 🎉', imageUrl:'', emoji:'👶🎬', likes:['m1','m4'], comments:[{author:'סבתא מרים',text:'ליבי התפוצץ!'},{author:'שרה',text:'בוכה 😭'}], date:'15 במאי 2025' },
  { id:'p3', authorId:'m1', authorName:'אני (מנהל)', text:'הפתעת יום הולדת 70 לאמא הצליחה! כולם טסו בסוד ✨', imageUrl:'', emoji:'🎂🎉🥂', likes:['m2','m3','m4'], comments:[], date:'12 במאי 2025' },
];

let editingId = null;

// ─── AUTH ─────────────────────────────────────────────────────────
function showAuthTab(t){
  document.getElementById('auth-login').style.display  = t==='login'  ? 'block':'none';
  document.getElementById('auth-signup').style.display = t==='signup' ? 'block':'none';
}

function setFamilyTab(tab){
  const isJoin = tab==='join';
  document.getElementById('su-panel-join').style.display   = isJoin?'block':'none';
  document.getElementById('su-panel-create').style.display = isJoin?'none':'block';
  const ON  = 'padding:9px;border-radius:10px;font-size:13px;font-weight:700;cursor:pointer;font-family:inherit;border:1.5px solid #f97316;background:linear-gradient(135deg,#f97316,#ec4899);color:#fff';
  const OFF = 'padding:9px;border-radius:10px;font-size:13px;font-weight:700;cursor:pointer;font-family:inherit;border:1.5px solid rgba(249,115,22,.4);background:transparent;color:rgba(249,115,22,.8)';
  document.getElementById('tab-join-btn').style.cssText   = isJoin?ON:OFF;
  document.getElementById('tab-create-btn').style.cssText = isJoin?OFF:ON;
  document.getElementById('btn-signup').textContent = isJoin?'הצטרף/י למשפחה קיימת 🔗':'צור משפחה חדשה והתחבר/י ✨';
}

function doLogin(){
  const email = document.getElementById('li-email').value.trim();
  const pass  = document.getElementById('li-pass').value;
  if(!email||!pass){ toast('אנא מלא/י אימייל וסיסמה','err'); return; }
  // Demo — any credentials
  currentUser = members.find(m=>m.isMe);
  enterApp();
}

function doSignUp(){
  const fn   = document.getElementById('su-fn').value.trim();
  const ln   = document.getElementById('su-ln').value.trim();
  const email= document.getElementById('su-email').value.trim();
  const pass = document.getElementById('su-pass').value;
  if(!fn||!ln||!email||!pass){ toast('אנא מלא/י את כל השדות','err'); return; }
  if(pass.length<6){ toast('הסיסמה חייבת להכיל לפחות 6 תווים','err'); return; }

  const isPanelCreate = document.getElementById('su-panel-create').style.display!=='none';
  const code = (isPanelCreate
    ? document.getElementById('su-new-code').value.trim()
    : document.getElementById('su-join-code').value.trim()
  ).toUpperCase();
  if(!code){ toast('אנא הכנס/י קוד משפחה','err'); return; }

